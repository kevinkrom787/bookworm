# Atlas environment variables
# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real keys.

# Flask
SECRET_KEY=change-this-to-a-random-string

# ── Image Search (pick one) ────────────────────────────────────────────────────
# Option A: Pixabay — free, easy, 1,500 requests/hour
#   1. Register at https://pixabay.com/accounts/register/
#   2. Go to https://pixabay.com/api/docs/ and copy your key
PIXABAY_API_KEY=

# Option B: Google Custom Search — best SafeSearch, 100/day free
#   1. Enable Custom Search API: https://console.cloud.google.com/
#   2. Create a search engine: https://cse.google.com/cse/all
#      - Set "Search the entire web" = ON
#      - Set "Image search" = ON
#   3. Copy your API key and Search Engine ID (cx)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
